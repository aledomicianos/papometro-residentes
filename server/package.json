{
  "name": "papometro-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":       "tsx watch src/server.ts",
    "build":     "tsc",
    "start":     "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed":   "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.16.2",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "helmet":         "^7.1.0"
  },
  "devDependencies": {
    "@types/cors":    "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node":    "^20.14.11",
    "prisma":         "^5.16.2",
    "tsx":            "^4.16.2",
    "typescript":     "^5.5.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
